Sub FindTrueLastMonthAcrossTimeline()

    Dim ws As Worksheet
    Set ws = ActiveSheet
    
    Dim idxCols As Variant
    Dim monthCols As Variant
    Dim i As Long, r As Long, lastRow As Long
    Dim dict As Object
    Dim idx As String
    Dim lastFoundMonth As String
    Dim outputRow As Long
    Dim key As Variant
    
    Set dict = CreateObject("Scripting.Dictionary")
    dict.CompareMode = vbTextCompare
    
    idxCols = Array("A", "D", "G", "J", "M", "P", "S", "V", "Y", "AB", "AE", "AH", "AK", "AN")
    monthCols = Array("B", "E", "H", "K", "N", "Q", "T", "W", "Z", "AC", "AF", "AI", "AL", "AO")
    
    ' Output clear
    ws.Range("AR1:AT" & ws.Rows.Count).ClearContents
    ws.Range("AR1:AT" & ws.Rows.Count).Interior.Pattern = xlNone
    
    ws.Range("AR1").Value = "INDEX NO"
    ws.Range("AS1").Value = "LAST MONTH"
    ws.Range("AT1").Value = "LAST COLUMN"
    
    ' সব timeline scan
    For i = LBound(idxCols) To UBound(idxCols)
        lastRow = ws.Cells(ws.Rows.Count, idxCols(i)).End(xlUp).Row
        
        For r = 2 To lastRow
            idx = Trim(CStr(ws.Cells(r, idxCols(i)).Value))
            
            If idx <> "" Then
                dict(idx) = Array(ws.Cells(r, monthCols(i)).Value, idxCols(i))
            End If
        Next r
    Next i
    
    outputRow = 2
    
    For Each key In dict.Keys
        ws.Cells(outputRow, "AR").Value = key
        ws.Cells(outputRow, "AS").Value = dict(key)(0)
        ws.Cells(outputRow, "AT").Value = dict(key)(1)
        outputRow = outputRow + 1
    Next key
    
    MsgBox "True last month tracking completed. দেখুন AR:AT কলামে।", vbInformation

End Sub
